# Dry run mode (scrape sans envoyer de messages)
DRY_RUN=true

# Server
PORT=3000

# Polling interval in ms (default: 90000 = 1.5min)
POLLING_INTERVAL_MS=90000

# Enable/disable scrapers per platform
LEBONCOIN_ENABLED=true
SELOGER_ENABLED=false

# Rate limiting
MAX_MESSAGES_PER_HOUR=5

# SMTP (for email sending)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# Chrome path (auto-detected if not set — uses system Chrome to avoid bot detection)
# CHROME_PATH=/mnt/c/Program Files/Google/Chrome/Application/chrome.exe

# Logging
LOG_LEVEL=info
